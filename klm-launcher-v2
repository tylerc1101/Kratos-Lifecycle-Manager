#!/usr/bin/env bash
set -Eeuo pipefail

# KLM lightweight launcher
# Purpose:
#   - bootstrap/install the updateable KLM core
#   - find KLM_HOME
#   - launch the Python core
#
# The heavy lifecycle logic lives in:
#   $KLM_HOME/core/current/bin/klm.py

KLM_HOME_DEFAULT="/opt/klm"
KLM_ENV_FILE="/etc/klm/klm.env"

die() {
  printf '[klm][ERROR] %s\n' "$*" >&2
  exit 1
}

log() {
  printf '[klm] %s\n' "$*" >&2
}

as_root() {
  if [[ "${EUID}" -eq 0 ]]; then
    "$@"
  else
    sudo "$@"
  fi
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

load_klm_home() {
  if [[ -n "${KLM_HOME:-}" ]]; then
    return
  fi

  if [[ -f "$KLM_ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$KLM_ENV_FILE"
  fi

  KLM_HOME="${KLM_HOME:-$KLM_HOME_DEFAULT}"
}

extract_yaml_value() {
  local file="$1"
  local dotted_key="$2"

  python3 - "$file" "$dotted_key" <<'PY'
import sys

path = sys.argv[1]
key = sys.argv[2].split(".")

try:
    import yaml
except Exception:
    yaml = None

if yaml:
    with open(path, "r", encoding="utf-8") as f:
        data = yaml.safe_load(f) or {}
    cur = data
    for part in key:
        if not isinstance(cur, dict) or part not in cur:
            print("")
            sys.exit(0)
        cur = cur[part]
    print(cur if cur is not None else "")
    sys.exit(0)

# Fallback only supports klm.home.
if ".".join(key) != "klm.home":
    print("")
    sys.exit(0)

in_klm = False
with open(path, "r", encoding="utf-8") as f:
    for line in f:
        raw = line.rstrip("\n")
        stripped = raw.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if not raw.startswith(" ") and stripped.startswith("klm:"):
            in_klm = True
            continue
        if in_klm and not raw.startswith(" "):
            in_klm = False
        if in_klm and stripped.startswith("home:"):
            print(stripped.split(":", 1)[1].strip().strip('"').strip("'"))
            sys.exit(0)

print("")
PY
}

install_core_archive() {
  local archive="$1"
  local requested_home="${2:-}"

  [[ -n "$archive" ]] || die "Usage: klm core install <klm-core.tgz> [--home <path>]"
  [[ -f "$archive" ]] || die "Core bundle not found: $archive"

  if [[ -n "$requested_home" ]]; then
    KLM_HOME="$requested_home"
  else
    load_klm_home
  fi

  need_cmd tar
  need_cmd mktemp
  need_cmd find

  as_root mkdir -p "$KLM_HOME/core" "$KLM_HOME/bin" /etc/klm

  local tmp
  tmp="$(mktemp -d)"

  tar -xzf "$archive" -C "$tmp"

  local core_dir
  core_dir="$(find "$tmp" -mindepth 1 -maxdepth 1 -type d | head -n1 || true)"

  [[ -n "$core_dir" ]] || die "Invalid core bundle: no root directory found"
  [[ -f "$core_dir/bin/klm.py" ]] || die "Invalid core bundle: missing bin/klm.py"

  local name
  name="$(basename "$core_dir")"

  as_root rm -rf "$KLM_HOME/core/$name"
  as_root cp -a "$core_dir" "$KLM_HOME/core/$name"
  as_root chmod +x "$KLM_HOME/core/$name/bin/klm.py"
  as_root ln -sfn "$KLM_HOME/core/$name" "$KLM_HOME/core/current"

  as_root tee "$KLM_ENV_FILE" >/dev/null <<EOF
KLM_HOME="$KLM_HOME"
EOF
  as_root chmod 0644 "$KLM_ENV_FILE"

  rm -rf "$tmp"

  log "Installed core: $name"
  log "KLM_HOME: $KLM_HOME"
}

bootstrap() {
  local config=""
  local core=""
  local home_override=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config|--deployment)
        config="${2:-}"
        shift 2
        ;;
      --core)
        core="${2:-}"
        shift 2
        ;;
      --home)
        home_override="${2:-}"
        shift 2
        ;;
      *)
        die "Unknown bootstrap argument: $1"
        ;;
    esac
  done

  [[ -n "$config" ]] || die "Missing --config <deployment.yml>"
  [[ -f "$config" ]] || die "Deployment config not found: $config"

  need_cmd python3

  local yaml_home
  yaml_home="$(extract_yaml_value "$config" "klm.home")"

  if [[ -n "$home_override" ]]; then
    KLM_HOME="$home_override"
  elif [[ -n "$yaml_home" ]]; then
    KLM_HOME="$yaml_home"
  else
    KLM_HOME="$KLM_HOME_DEFAULT"
  fi

  if [[ -z "$core" ]]; then
    local bundle_root core_file config_dir
    bundle_root="$(extract_yaml_value "$config" "klm.bundle_root")"
    core_file="$(extract_yaml_value "$config" "klm.core.file")"
    config_dir="$(cd "$(dirname "$config")" && pwd)"

    [[ -n "$core_file" ]] || die "Missing --core and deployment.yml does not define klm.core.file"

    if [[ "$core_file" = /* ]]; then
      core="$core_file"
    else
      if [[ -n "$bundle_root" ]]; then
        [[ "$bundle_root" = /* ]] || bundle_root="$config_dir/$bundle_root"
        core="$bundle_root/$core_file"
      else
        core="$config_dir/$core_file"
      fi
    fi
  fi

  install_core_archive "$core" "$KLM_HOME"
}

show_help() {
  cat <<EOF
KLM launcher

Usage:
  klm bootstrap --config <deployment.yml> [--core <klm-core.tgz>] [--home <path>]
  klm core install <klm-core.tgz> [--home <path>]
  klm core current
  klm <command>

Examples:
  sudo install -m 0755 ./klm-launcher /usr/local/bin/klm
  sudo klm bootstrap --config ./deployment.yml
  sudo klm init --config ./deployment.yml
  klm menu
EOF
}

case "${1:-}" in
  bootstrap)
    shift
    bootstrap "$@"
    ;;
  core)
    shift
    case "${1:-}" in
      install)
        shift
        archive="${1:-}"
        [[ -n "$archive" ]] || die "Usage: klm core install <klm-core.tgz> [--home <path>]"
        shift || true

        home_arg=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --home)
              home_arg="${2:-}"
              shift 2
              ;;
            *)
              die "Unknown core install argument: $1"
              ;;
          esac
        done

        install_core_archive "$archive" "$home_arg"
        ;;
      current)
        load_klm_home
        readlink -f "$KLM_HOME/core/current"
        ;;
      *)
        die "Usage: klm core {install <klm-core.tgz>|current}"
        ;;
    esac
    ;;
  help|--help|-h)
    show_help
    ;;
  *)
    load_klm_home
    KLM_PY="$KLM_HOME/core/current/bin/klm.py"
    [[ -f "$KLM_PY" ]] || die "KLM core is not installed. Run: klm bootstrap --config <deployment.yml>"
    exec python3 "$KLM_PY" "$@"
    ;;
esac
